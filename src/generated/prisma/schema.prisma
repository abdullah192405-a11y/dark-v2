generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String             @id @default(uuid())
  clerkUserId      String             @unique
  email            String             @unique
  name             String?
  imageUrl         String?
  phone            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  role             UserRole           @default(USER)
  TestDriveBooking TestDriveBooking[]
  UserSavedCar     UserSavedCar[]
  articles         Article[]
}

model Car {
  id                 String    @id @default(uuid())
  make               String
  model              String
  year               Int
  price              Decimal   @db.Decimal(10, 2)
  mileage            Int
  color              String
  fuelType           String
  transmission       String
  bodyType           String
  seats              Int?
  description        String
  category           String?
  videoUrl           String?
  status             CarStatus @default(AVAILABLE)
  featured           Boolean   @default(false)
  testDriveAvailable Boolean   @default(true)

  images            String[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  testDriveBookings TestDriveBooking[]
  savedBy           UserSavedCar[]
  loanRequests      LoanRequest[]

  @@index([make, model])
  @@index([bodyType])
  @@index([price])
  @@index([year])
  @@index([status])
  @@index([fuelType])
  @@index([featured])
}

model DealershipInfo {
  id           String        @id @default(uuid())
  name         String        @default("Click Car Motors")
  address      String        @default("69 Car Street, Autoville, CA 69420")
  phone        String        @default("+1 (555) 123-4567")
  email        String        @default("contact@clickcar.com")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workingHours WorkingHour[]
}

model WorkingHour {
  id           String         @id @default(uuid())
  dealershipId String
  dayOfWeek    DayOfWeek
  openTime     String
  closeTime    String
  isOpen       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  dealership   DealershipInfo @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, dayOfWeek])
  @@index([dealershipId])
  @@index([dayOfWeek])
  @@index([isOpen])
}

model UserSavedCar {
  id      String   @id @default(uuid())
  userId  String
  carId   String
  savedAt DateTime @default(now())
  car     Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
  @@index([userId])
  @@index([carId])
}

model TestDriveBooking {
  id          String        @id @default(uuid())
  carId       String
  userId      String
  bookingDate DateTime      @db.Date
  startTime   String
  endTime     String
  status      BookingStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  car         Car           @relation(fields: [carId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@index([carId])
  @@index([userId])
  @@index([bookingDate])
  @@index([status])
}

model ChatLog {
  id               String   @id @default(uuid())
  userId           String? // Optional - for tracking authenticated users
  sessionId        String // For tracking anonymous users
  userMessage      String   @db.Text
  correctedMessage String?  @db.Text // Spelling-corrected version of user message (if different)
  aiResponse       String   @db.Text
  carsFound        Int      @default(0)
  carsShown        Int      @default(0)
  carIds           String[] // Array of car IDs that were shown
  language         String   @default("ar") // ar for Arabic, en for English
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([language])
}

model FeaturedBrand {
  id        String   @id @default(uuid())
  name      String // Brand name in English
  nameAr    String // Brand name in Arabic
  image     String // Image URL
  order     Int      @default(0) // Display order
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}

model FeaturedModel {
  id        String   @id @default(uuid())
  name      String // Model name in English
  nameAr    String // Model name in Arabic
  image     String // Image URL
  order     Int      @default(0) // Display order
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}

enum UserRole {
  USER
  ADMIN
}

enum CarStatus {
  AVAILABLE
  UNAVAILABLE
  SOLD
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LoanRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model Bank {
  id           String        @id @default(uuid())
  name         String
  logoImage    String
  interestRate Decimal       @db.Decimal(5, 2) // سعر الفائدة
  loanPolicy   String? // سياسة القرض
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  loanRequests LoanRequest[]
}

model Article {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  content         String    @db.Text // Keep for backward compatibility
  contentSections Json? // New field for rich content
  excerpt         String?
  authorId        String?
  author          User?     @relation(fields: [authorId], references: [id])
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  image           String?
  tags            String[]

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
  @@index([authorId])
}

model Review {
  id         String   @id @default(uuid())
  clientName String
  city       String
  car        String
  rating     Int // Rating from 1 to 5
  videoUrl   String?
  imageUrl   String?
  reviewText String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([rating])
  @@index([createdAt])
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model LoanRequest {
  id    String @id @default(uuid())
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  // Personal Information
  fullName     String
  email        String
  mobileNumber String
  city         String
  time         String // Preferred contact time

  // ID Information
  idNumber String
  idImage  String? // URL/path to uploaded ID image

  // Car Information (from form, may differ from actual car)
  carMake     String
  carModel    String
  carCategory String?
  carYear     Int

  // Birth Information
  birthMonth String // Hijri month (1-12)
  birthYear  String

  // Gender
  gender String // "male" or "female"

  // Loan Details
  loanAmount     Decimal  @db.Decimal(12, 2)
  downPayment    Decimal  @db.Decimal(12, 2)
  loanTerm       Int // in years
  monthlyPayment Decimal? @db.Decimal(12, 2) // Selected monthly payment
  interestRate   Decimal? @db.Decimal(5, 2) // Selected interest rate
  finalPayment   Decimal? @db.Decimal(12, 2) // Total final payment

  // Financial Information
  netSalary            Decimal? @db.Decimal(12, 2)
  employerSector       String? // "خاص", "حكومي مدني", "حكومي عسكرى", "متقاعد"
  employer             String?
  salaryTransferBankId String?
  salaryTransferBank   Bank?    @relation(fields: [salaryTransferBankId], references: [id])

  // Credit Information
  hasRealEstateFinance    Boolean? // true if has real estate finance
  hasCreditDefault        Boolean? // true if has credit default
  totalMonthlyObligations Decimal? @db.Decimal(12, 2)

  // Additional Information
  additionalInfo String? @db.Text

  // Status and timestamps
  status    LoanRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([carId])
  @@index([email])
  @@index([mobileNumber])
  @@index([status])
  @@index([createdAt])
}
